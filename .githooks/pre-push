#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

echo "========================================="
echo "  Pre-push checks: rds-iop-killer"
echo "========================================="

FAILED=0

# --------------------------------------------------
# 1. Sync README.md from CLAUDE.md
# --------------------------------------------------
echo ""
echo -e "${YELLOW}[1/3] Syncing README.md from CLAUDE.md...${NC}"

if [ -f CLAUDE.md ]; then
  if ! diff -q CLAUDE.md README.md >/dev/null 2>&1; then
    cp CLAUDE.md README.md
    git add README.md
    git commit -m "docs: sync README.md from CLAUDE.md" --no-verify 2>/dev/null || true
    echo -e "${GREEN}  README.md synced and committed.${NC}"
  else
    echo -e "${GREEN}  README.md already in sync.${NC}"
  fi
else
  echo -e "${RED}  CLAUDE.md not found!${NC}"
  FAILED=1
fi

# --------------------------------------------------
# 2. PII / Secrets / Sensitive data scan
# --------------------------------------------------
echo ""
echo -e "${YELLOW}[2/3] Scanning for PII, secrets, and sensitive data...${NC}"

# Patterns to flag — case-insensitive grep across tracked files
PII_PATTERNS=(
  # API keys and tokens (actual values, not variable names)
  'AKIA[0-9A-Z]{16}'                          # AWS Access Key ID
  '[0-9a-zA-Z/+]{40}'                          # (too broad on its own, paired below)
  'sk-[a-zA-Z0-9]{20,}'                        # OpenAI / Stripe secret keys
  'ghp_[a-zA-Z0-9]{36}'                        # GitHub PAT
  'xox[bpas]-[a-zA-Z0-9\-]+'                   # Slack tokens

  # Hardcoded credentials
  'password\s*[:=]\s*["\x27][^"\x27]{4,}'      # password = "..." or password: "..."
  'secret\s*[:=]\s*["\x27][^"\x27]{4,}'        # secret = "..."
  'api[_-]?key\s*[:=]\s*["\x27][^"\x27]{4,}'   # api_key = "..."
  'api[_-]?token\s*[:=]\s*["\x27][^"\x27]{4,}' # api_token = "..."

  # Private keys
  'BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY'

  # .env file contents committed
  'CONFLUENCE_API_TOKEN=.+'
  'JIRA_API_TOKEN=.+'
  'AWS_SECRET_ACCESS_KEY=.+'
  'DATABASE_PASSWORD=.+'
)

# Files/dirs to exclude from the scan
EXCLUDE_ARGS=(
  --exclude-dir=node_modules
  --exclude-dir=.git
  --exclude-dir=dist
  --exclude='*.lock'
  --exclude='package-lock.json'
  --exclude='pre-push'
)

PII_FOUND=0
for pattern in "${PII_PATTERNS[@]}"; do
  MATCHES=$(grep -rniE "${EXCLUDE_ARGS[@]}" "$pattern" . 2>/dev/null || true)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}  MATCH for pattern: ${pattern}${NC}"
    echo "$MATCHES" | head -5 | sed 's/^/    /'
    PII_FOUND=1
  fi
done

# Check for .env files being committed
ENV_FILES=$(git diff --cached --name-only 2>/dev/null | grep -E '\.env$|\.env\.' || true)
if [ -z "$ENV_FILES" ]; then
  ENV_FILES=$(git diff --name-only HEAD 2>/dev/null | grep -E '\.env$|\.env\.' || true)
fi
if [ -n "$ENV_FILES" ]; then
  echo -e "${RED}  .env file(s) staged for commit:${NC}"
  echo "$ENV_FILES" | sed 's/^/    /'
  PII_FOUND=1
fi

# Check for common sensitive filenames
SENSITIVE_FILES=$(git ls-files | grep -iE '(credentials|secrets|private.key|\.pem|\.p12|\.pfx|id_rsa)' || true)
if [ -n "$SENSITIVE_FILES" ]; then
  echo -e "${RED}  Sensitive file(s) tracked in git:${NC}"
  echo "$SENSITIVE_FILES" | sed 's/^/    /'
  PII_FOUND=1
fi

if [ "$PII_FOUND" -eq 1 ]; then
  echo ""
  echo -e "${RED}  !! Potential PII/secrets found. Review above and remove before pushing.${NC}"
  echo -e "${RED}  !! To bypass (use with caution): git push --no-verify${NC}"
  FAILED=1
else
  echo -e "${GREEN}  No PII or secrets detected.${NC}"
fi

# --------------------------------------------------
# 3. TypeScript type-check
# --------------------------------------------------
echo ""
echo -e "${YELLOW}[3/3] Running TypeScript type-checks...${NC}"

if npx -w server tsc --noEmit 2>&1; then
  echo -e "${GREEN}  Server: passed${NC}"
else
  echo -e "${RED}  Server: type errors found${NC}"
  FAILED=1
fi

if npx -w client tsc --noEmit 2>&1; then
  echo -e "${GREEN}  Client: passed${NC}"
else
  echo -e "${RED}  Client: type errors found${NC}"
  FAILED=1
fi

# --------------------------------------------------
# Result
# --------------------------------------------------
echo ""
if [ "$FAILED" -eq 1 ]; then
  echo -e "${RED}=========================================${NC}"
  echo -e "${RED}  Pre-push checks FAILED. Push blocked.${NC}"
  echo -e "${RED}=========================================${NC}"
  exit 1
else
  echo -e "${GREEN}=========================================${NC}"
  echo -e "${GREEN}  All pre-push checks passed!${NC}"
  echo -e "${GREEN}=========================================${NC}"
  exit 0
fi
